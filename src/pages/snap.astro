---
import "../styles/global.css";
import { User, Menu, Play } from "@lucide/astro";
import { Icon } from "astro-icon/components";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Astro</title>
    </head>
    <body class="bg-black/90 text-white font-space-grotesk overflow-x-hidden!">
        <main id="smooth-content">
            <button id="ham-menu-btn" class="absolute w-8 h-8 right-6 sm:right-8 top-6 cursor-pointer z-20 block md:hidden">
                <span class="absolute top-0 right-0 w-8 h-0.5 bg-white rounded-full"></span>
                <span class="absolute top-0 right-0 w-8 h-0.5 bg-white rounded-full"></span>
            </button>

            <!-- Side Menu -->
            <div
                id="sidebar"
                class="backdrop-blur-[2px] bg-black/90 w-screen p-8 absolute right-0 flex justify-center gap-8 flex-col h-screen z-10"
            >
                <p class="rounded-sm absolute top-6 left-8 font-extrabold text-2xl">ARCANE</p>
                <div id="sidebar-link" class="flex items-center group gap-3 cursor-pointer">
                    <div class="w-6 h-6 rounded-full bg-[#888] group-hover:scale-150 group-hover:bg-orange-500 duration-150"></div>
                    <div
                        class="text-5xl font-extrabold text-[#999] tracking-tighter group-hover:text-white group-hover:translate-x-3 group-hover:scale-110 scale:150 origin-left duration-150"
                    >
                        HOME
                    </div>
                </div>

                <div id="sidebar-link" class="flex items-center group gap-3 cursor-pointer">
                    <div class="w-6 h-6 rounded-full bg-[#888] group-hover:scale-150 group-hover:bg-orange-500 duration-150"></div>
                    <div
                        class="text-5xl font-extrabold text-[#999] tracking-tighter group-hover:text-white group-hover:translate-x-3 group-hover:scale-110 scale:150 origin-left duration-150"
                    >
                        ABOUT
                    </div>
                </div>

                <div id="sidebar-link" class="flex items-center group gap-3 cursor-pointer">
                    <div class="w-6 h-6 rounded-full bg-[#888] group-hover:scale-150 group-hover:bg-orange-500 duration-150"></div>
                    <div
                        class="text-5xl font-extrabold text-[#999] tracking-tighter group-hover:text-white group-hover:translate-x-3 group-hover:scale-110 scale:150 origin-left duration-150"
                    >
                        SERVICES
                    </div>
                </div>

                <div id="sidebar-link" class="flex items-center group gap-3 cursor-pointer">
                    <div class="w-6 h-6 rounded-full bg-[#888] group-hover:scale-150 group-hover:bg-orange-500 duration-150"></div>
                    <div
                        class="text-5xl font-extrabold text-[#999] tracking-tighter group-hover:text-white group-hover:translate-x-3 group-hover:scale-110 scale:150 origin-left duration-150"
                    >
                        CONTACT US
                    </div>
                </div>
            </div>
            <!-- Side Menu -->

            <section id="hero" class="h-screen relative overflow-hidden">
                <div class="absolute lg:hidden inset-0 bg-linear-to-r from-white/50 via-white/30 to-transparent"></div>
                <div class="absolute inset-x-0 top-0 h-32 bg-linear-to-b from-black/70 to-transparent"></div>
                <div id="hero-img" class="absolute inset-0 bg-[url('/arcane0.jpg')] -z-10 bg-cover bg-position-[70%_center] bg-no-repeat">
                </div>
                <header class="grid grid-cols-3 items-center w-full px-2 sm:px-8 py-4">
                    <p id="logo" class="rounded-sm font-extrabold text-2xl w-[4ch] tracking-tight leading-5">RIOT GAMES</p>
                    <nav class="justify-self-center hidden md:block">
                        <ul
                            class="flex items-center gap-1 px-3 py-2.5 rounded-full bg-black/50 backdrop-blur-2xl border border-white/10
                                text-white/70 text-sm *:font-bold"
                        >
                            <li>
                                <a
                                    class="hover:text-white transition-colors duration-150 px-5 py-2 rounded-full
                                                hover:bg-white/5"
                                    href="/">Home</a
                                >
                            </li>
                            <li>
                                <a
                                    class="hover:text-white transition-colors duration-150 px-5 py-2 rounded-full
                                                hover:bg-white/5"
                                    href="/">About</a
                                >
                            </li>
                            <li>
                                <a
                                    class="hover:text-white transition-colors duration-150 px-5 py-2 rounded-full
                                                hover:bg-white/5"
                                    href="/">Pricing</a
                                >
                            </li>
                            <li>
                                <a
                                    class="hover:text-white transition-colors duration-150 px-5 py-2 rounded-full
                                                hover:bg-white/5"
                                    href="/">Contact</a
                                >
                            </li>
                        </ul>
                    </nav>
                </header>
                <div class="text-6xl sm:text-7xl lg:text-8xl top-50 left-5 text-black font-extrabold w-120 absolute">
                    <p class="title">MEET</p>
                    <p class="title">THE</p>
                    <p class="title">LEGENDS</p>

                    <div class="flex flex-col items-center gap-2 w-40 md:w-60 mt-8">
                        <p class="explore text-lg font-bold">Scroll</p>
                        <div class="explore">
                            <Icon name="tabler:arrow-narrow-down" class="animate-bounce w-6 h-6" />
                        </div>
                    </div>
                </div>
                <div
                    class="start-banner overflow-hidden z-30 absolute bg-gray-900 bottom-0 h-screen w-screen flex justify-center items-center"
                >
                    <p id="arcane" class="font-extrabold text-7xl sm:text-9xl">ARCANE</p>
                </div>
                <aside class="flex flex-col gap-4 absolute left-5 bottom-10">
                    <div class="social-link">
                        <Icon
                            name="tabler:brand-facebook"
                            class="cursor-pointer hover:scale-125 duration-150 border border-black rounded-full h-8 w-8 p-1.5 grid place-items-center text-black"
                        />
                    </div>
                    <div class="social-link">
                        <Icon
                            name="tabler:brand-x"
                            class="cursor-pointer hover:scale-125 duration-150 border border-black rounded-full h-8 w-8 p-1.5 grid place-items-center text-black"
                        />
                    </div>
                    <div class="social-link">
                        <Icon
                            name="tabler:brand-instagram"
                            class="cursor-pointer hover:scale-125 duration-150 border border-black rounded-full h-8 w-8 p-1.5 grid place-items-center text-black"
                        />
                    </div>
                </aside>

                <div class="start-banner overflow-hidden z-20 text-4xl absolute bg-blue-900 bottom-0 h-screen w-screen"></div>
                <div class="start-banner overflow-hidden z-10 text-4xl absolute bg-purple-900 bottom-0 h-screen w-screen"></div>

                <div class="start-banner overflow-hidden z-9 text-4xl absolute bg-emerald-900 bottom-0 h-screen w-screen"></div>
            </section>
            <!-- fix mobile screen amount of text affects images -->
            <section id="second-section" class="relative h-screen overflow-hidden grid place-items-center">
                <div id="second-section-bg" class="absolute inset-0 bg-[url('/bg2.png')] bg-cover bg-position-[30%_center] -z-10"></div>

                <div class="w-[80vw] h-[90svh] lg:h-[70vh] relative rounded-md">
                    <div id="cards-wrapper" class="h-full w-full *:absolute *:inset-0">
                        <div class="card h-full w-full flex flex-col lg:flex-row items-center justify-center gap-6 sm:gap-20">
                            <div
                                class="card-image -rotate-2 bg-[url('/characters/jinx.avif')] rounded-lg h-full w-full sm:w-100 bg-cover bg-center"
                            >
                            </div>
                            <div class="card-text text-center h-[50%]">
                                <p class="text-4xl lg:text-5xl font-extrabold">JINX</p>
                                <p class="max-w-96 text-sm lg:text-lg">
                                    Jinx was torn between two identities: the strong, powerful, daughter Silco raised and the fearful, weak,
                                    little sister Vi protected. Now, accepting she’s the monster that Vi created, Jinx becomes a hollow
                                    shell—she is the cursed "Jinx" that ruins everything.
                                </p>
                            </div>
                        </div>
                        <div class="card h-full w-full flex flex-col lg:flex-row items-center justify-center gap-6 sm:gap-20">
                            <div
                                class="card-image bg-[url('/characters/vi.avif')] rotate-2 rounded-lg h-full w-full sm:w-100 bg-cover bg-center"
                            >
                            </div>
                            <div class="card-text text-center h-[50%]">
                                <p class="text-4xl lg:text-5xl font-extrabold">VI</p>
                                <p class="max-w-96 text-sm lg:text-lg">
                                    Accepting Powder is gone, Vi comes to terms with what she must do—handle the monster she created: Jinx.
                                    Knowing how dangerous her sister is, Vi teams up with Caitlyn and gives in to her request to don the
                                    Enforcer badge.
                                </p>
                            </div>
                        </div>

                        <div class="card h-full w-full flex flex-col lg:flex-row items-center justify-center gap-6 sm:gap-20">
                            <div
                                class="card-image -rotate-3 origin-bottom-right bg-[url('/characters/caitlyn.avif')] rounded-lg h-full w-full sm:w-100 bg-cover bg-center"
                            >
                            </div>
                            <div class="card-text text-center h-[50%]">
                                <p class="text-4xl lg:text-5xl font-extrabold">CAITLYN</p>
                                <p class="max-w-96 text-sm lg:text-lg">
                                    Caitlyn is an Enforcer from Piltover. She once used her investigative prowess to expose the source of
                                    corruption in Zaun and Piltover, but after Jinx’s attack on the council, she’s abandoned hope for peace.
                                </p>
                            </div>
                        </div>

                        <div class="card h-full w-full flex flex-col lg:flex-row items-center justify-center gap-6 sm:gap-20">
                            <div
                                class="card-image rotate-4 bg-[url('/characters/ekko.avif')] rounded-lg h-full w-full sm:w-100 bg-cover bg-center"
                            >
                            </div>
                            <div class="card-text text-center h-[50%]">
                                <p class="text-4xl lg:text-5xl font-extrabold">EKKO</p>
                                <p class="max-w-96 text-sm lg:text-lg">
                                    Ekko empowers the Firelights, a group of Zaunites who build a new home they all fight to protect. He
                                    found an unlikely friend in Heimerdinger, and together they strive to make Zaun better.
                                </p>
                            </div>
                        </div>

                        <div class="card h-full w-full flex flex-col lg:flex-row items-center justify-center gap-6 sm:gap-20">
                            <div
                                class="card-image -rotate-3 bg-[url('/characters/heimerdinger.avif')] rounded-lg h-full w-full sm:w-100 bg-cover bg-center"
                            >
                            </div>
                            <div class="card-text text-center h-[50%]">
                                <p class="text-4xl lg:text-5xl font-extrabold">HEIMERDINGER</p>
                                <p class="max-w-96 text-sm lg:text-lg">
                                    Heimerdinger warned the Piltover Council about the dangers of using magic without tangible solutions for
                                    safeguarding its use. Learning from his mistakes with Jayce, Heimerdinger inspires Ekko to keep looking
                                    for a solution and works with him to solve the problem, instead of just offering advice.
                                </p>
                            </div>
                        </div>

                        <div class="card h-full w-full flex flex-col lg:flex-row items-center justify-center gap-6 sm:gap-20">
                            <div
                                class="card-image rotate-4 origin-bottom-left bg-[url('/characters/jayce.avif')] rounded-lg h-full w-full sm:w-100 bg-cover bg-center"
                            >
                            </div>
                            <div class="card-text text-center h-[50%]">
                                <p class="text-4xl lg:text-5xl font-extrabold">JAYCE</p>
                                <p class="max-w-96 text-sm lg:text-lg">
                                    After a series of events, Jayce questions his vision of using Hextech to better the lives of Piltovans.
                                    Meanwhile, together with Heimerdinger and Ekko, Jayce discovers that the use of Hextech has been
                                    poisoning the undercity. And as they investigate, they come across something more.
                                </p>
                            </div>
                        </div>

                        <div class="card h-full w-full flex flex-col lg:flex-row items-center justify-center gap-6 sm:gap-20">
                            <div
                                class="card-image bg-[url('/characters/viktor.avif')] rounded-lg h-full w-full sm:w-100 bg-cover bg-center"
                            >
                            </div>
                            <div class="card-text text-center h-[50%]">
                                <p class="text-4xl lg:text-5xl font-extrabold">VIKTOR</p>
                                <p class="max-w-96 text-sm lg:text-lg">
                                    Viktor pushes the limits of Hextech despite warnings of its dangers. Driven by guilt, Viktor sets out to
                                    fulfill his dream of giving Hextech to the people.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <section
                id="outro-sec"
                class="h-screen grid place-items-center overflow-hidden bg-[linear-gradient(180deg,#000000,#364549)] bg-size-[200%_200%]"
            >
                <p id="outro" class="max-w-4xl text-4xl tracking-wider text-center leading-normal">
                    Lorem ipsum dolor sit amet consectetur adipisicing elit. Porro reiciendis ex explicabo sed inventore commodi? <span
                        class="text-cyan-300">Nemo deleniti reiciendis</span
                    >, mollitia aliquid reprehenderit officia! Sint, nulla?
                </p>
            </section>

            <section id="video-sec" class="h-screen overflow-hidden relative">
                <video autoplay muted playsinline class="absolute inset-0 h-full w-full object-cover">
                    <source
                        src="https://cmsassets.rgpub.io/sanity/files/dsfx7636/news/8ca377434ec75445478d3d5d88acbd2aa5e8e86c.mp4?accountingTag=ARCANE"
                        type="video/mp4"
                    />
                </video>

                <div class="absolute inset-0 bg-black/50"></div>

                <div class="relative z-10 flex h-full items-center justify-center">
                    <div id="play-wrapper" class="h-[60vh] absolute top-0">
                        <div id="hole" class="w-48 h-5 bg-black/70 rounded-[50%] absolute top-[77%] right-1/2 translate-x-1/2"></div>

                        <div class="h-[80%] w-96 mx-auto relative overflow-hidden rounded-[50%]">
                            <button id="play-btn" class="mx-auto absolute bottom-0 right-1/2 translate-x-1/2" id="play-btn"
                                ><Play class="w-26 h-26 text-[#e80916] hover:scale-125 duration-150 cursor-pointer" /></button
                            >
                        </div>
                    </div>

                    <div class="text-center text-6xl font-bold mt-30 tracking-tighter">
                        <p id="watch">WATCH</p>
                        <p id="now">NOW</p>
                    </div>
                </div>
            </section>
            <section
                id="outro-sec"
                class="relative grid place-items-center py-16 px-4 min-h-screen bg-[url('/bg-6.png')] bg-no-repeat bg-cover"
            >
                <div class="flex gap-12 items-center flex-col lg:flex-row">
                    <div class="relative order-2 lg:order-1">
                        <div class="absolute inset-0 rounded-full border border-[#808bb0] scale-105"></div>

                        <div class="relative max-w-150 max-h-150 rounded-full overflow-hidden">
                            <img id="game-img-holder" src="/league-of-legends.jpg" class="w-full h-full object-cover" />
                        </div>
                    </div>
                    <div class="flex flex-col items-center gap-4 sm:gap-12 order-1 lg:order-2">
                        <p id="outro" class="max-w-[8ch] font-extrabold text-5xl sm:text-6xl tracking-wider text-center">
                            PLAY OUR <span class="text-cyan-500">GAMES</span>
                        </p>
                        <div class="flex flex-row flex-wrap gap-6 justify-center items-center">
                            <button
                                class="w-50 h-24 bg-cyan-600 rounded-md text-white text-xl font-extrabold tracking-widest hover:scale-105 transition-transform duration-150 cursor-pointer"
                            >
                                PLAY FREE
                            </button>

                            <button
                                class="w-50 h-24 bg-cyan-600 rounded-md text-white text-xl font-extrabold tracking-widest hover:scale-105 transition-transform duration-150 cursor-pointer"
                            >
                                LEARN MORE
                            </button>
                        </div>
                        <div class="flex flex-wrap gap-4 scale-80 sm:scale-100">
                            <button
                                id="lol-btn"
                                class="active-game-btn flex flex-col gap-4 max-w-24 opacity-60 hover:opacity-100 hover:scale-110 cursor-pointer duration-100"
                            >
                                <img src="/league-of-legends-logo.png" />
                                <p class="max-w-[10ch] text-center font-bold">LEAGUE OF LEGENDS</p>
                            </button>
                            <button
                                id="valorant-btn"
                                class="flex flex-col gap-4 max-w-24 opacity-60 hover:opacity-100 hover:scale-110 cursor-pointer duration-100"
                            >
                                <img src="/valorant-logo.png" />
                                <p class="max-w-[10ch] text-center font-bold">VALORANT</p>
                            </button>
                            <button
                                id="lor-btn"
                                class="flex flex-col gap-4 max-w-24 opacity-60 hover:opacity-100 hover:scale-110 cursor-pointer duration-100"
                            >
                                <img src="/legends-of-runeterra-logo.png" />
                                <p class="max-w-[10ch] text-center font-bold">LEGENDS OF RUNETERRA</p>
                            </button>
                        </div>
                    </div>
                </div>
            </section>

            <section id="outro-sec" class="relative -mt-8 z-20 min-h-[80svh] rounded-t-4xl rounded-b-4xl overflow-hidden bg-black">
                <div class="flex flex-col sm:flex-row">
                    <div class="w-64 h-fit mx-auto">
                        <img src="/arcane-league-of-legends.png" />
                    </div>
                    <div class="p-8 sm:w-full sm:max-w-[50vw]">
                        <ul class="flex flex-col text-4xl font-bold group">
                            <li class="border-b border-white/50 py-1 group-hover:opacity-50 hover:opacity-100 cursor-pointer duration-100">
                                <a>About</a>
                            </li>
                            <li class="border-b border-white/50 py-1 group-hover:opacity-50 hover:opacity-100 cursor-pointer duration-100">
                                <a>Brands</a>
                            </li>
                            <li class="border-b border-white/50 py-1 group-hover:opacity-50 hover:opacity-100 cursor-pointer duration-100">
                                <a>Careers</a>
                            </li>
                            <li class="border-b border-white/50 py-1 group-hover:opacity-50 hover:opacity-100 cursor-pointer duration-100">
                                <a>Pricing</a>
                            </li>
                            <li class="border-b border-white/50 py-1 group-hover:opacity-50 hover:opacity-100 cursor-pointer duration-100">
                                <a>Contact</a>
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="mt-8 flex flex-wrap gap-8 justify-center group">
                    <Icon
                        name="tabler:brand-youtube"
                        class="cursor-pointer group-hover:opacity-50 hover:opacity-100 duration-75 h-10 w-10"
                    />
                    <Icon
                        name="tabler:brand-tiktok"
                        class="cursor-pointer group-hover:opacity-50 hover:opacity-100 duration-75 h-10 w-10"
                    />
                    <Icon
                        name="tabler:brand-facebook"
                        class="cursor-pointer group-hover:opacity-50 hover:opacity-100 duration-75 h-10 w-10"
                    />
                    <Icon name="tabler:brand-x" class="cursor-pointer group-hover:opacity-50 hover:opacity-100 duration-75 h-10 w-10" />
                    <Icon
                        name="tabler:brand-instagram"
                        class="cursor-pointer group-hover:opacity-50 hover:opacity-100 duration-75 h-10 w-10"
                    />
                    <Icon
                        name="tabler:brand-spotify"
                        class="cursor-pointer group-hover:opacity-50 hover:opacity-100 duration-75 h-10 w-10"
                    />
                </div>

                <div class="mt-20 w-full text-sm font-mono flex flex-col items-center gap-2 sm:flex-row justify-around flex-wrap">
                    <a>
                        © {new Date().getFullYear()} ARCANE
                    </a>
                    <a>TERMS & CONDITIONS</a>
                    <a>PATENTS</a>
                    <a>PRIVACY POLICY</a>
                    <a>MANAGE COOKIES</a>
                </div>
            </section>
        </main>
    </body>
    <script>
        import { gsap } from "gsap";
        import { GSDevTools } from "gsap/GSDevTools";
        import { ScrollSmoother } from "gsap/ScrollSmoother";
        import { ScrollTrigger } from "gsap/ScrollTrigger";
        import { SplitText } from "gsap/SplitText";
        import TextPlugin from "gsap/TextPlugin";
        // import Lenis from "lenis";
        document.addEventListener("DOMContentLoaded", () => {
            gsap.registerPlugin(SplitText, GSDevTools, ScrollTrigger, TextPlugin, ScrollSmoother);
            ScrollSmoother.create({
                smooth: 1,
                effects: true,
            });
            // // Initialize a new Lenis instance for smooth scrolling
            // const lenis = new Lenis();
            //
            // // Synchronize Lenis scrolling with GSAP's ScrollTrigger plugin
            // lenis.on("scroll", ScrollTrigger.update);
            //
            // // Add Lenis's requestAnimationFrame (raf) method to GSAP's ticker
            // // This ensures Lenis's smooth scroll animation updates on each GSAP tick
            // gsap.ticker.add((time) => {
            //     lenis.raf(time * 1000); // Convert time from seconds to milliseconds
            // });
            //
            // // Disable lag smoothing in GSAP to prevent any delay in scroll animations
            // gsap.ticker.lagSmoothing(0);
            //
            const splitted = SplitText.create("#outro", { type: "words" });
            gsap.from(splitted.words, {
                y: -40,
                stagger: 0.04,
                opacity: 0,
                ease: "back",

                // scrollTrigger: {
                //     trigger: "#outro-sec",
                //     // scroller: "#main-scroller",
                //     // markers: true,
                //     start: "top center",
                //     // end: "bottom 80%",
                //     toggleActions: "play pause resume reset",
                //     // scrub: true,
                // },
            });

            const splittedArcane = SplitText.create("#arcane", { type: "chars" });
            const tl = gsap.timeline({});

            tl
                // .to("#enemy", { text: "ENEMY", duration: 2, ease: "linear" })
                .from(splittedArcane.chars, { scale: 4, delay: 0.5, stagger: 0.15, ease: "power4.out", opacity: 0 })
                .to(".start-banner", { opacity: 0.3, duration: 1, delay: 1, stagger: 0.02, y: "100vh", ease: "power1.inOut", yoyo: true })
                .to(splittedArcane.chars, { y: 180, stagger: 0.05, ease: "power1.in" }, "<")
                .from("#hero-img", { scale: 1.5, duration: 1, ease: "power1.inOut" }, "<")
                .from("#logo", { x: -200, duration: 1, ease: "power4.out" }, "<")
                .from("nav", { y: -300, duration: 1, ease: "power4.out" }, "<")

                .from(
                    ".social-link",
                    {
                        x: -300,
                        duration: 1,
                        stagger: 0.1,
                        rotation: 900,
                        ease: "power4.out",
                    },
                    "<0.3",
                )

                .from(
                    ".title",
                    {
                        opacity: 0,
                        y: 80,
                        scale: 3,
                        filter: "blur(15px)",
                        duration: 1,
                        stagger: 0.18,
                        ease: "power4.out",
                    },
                    "<0.7",
                )

                .addLabel("stop")
                .from(".explore", {
                    y: 100,
                    opacity: 0,
                    stagger: 0.1,
                    ease: "power1.out",
                });
            tl.seek("stop").play();
            // GSDevTools.create({ animation: tl });

            gsap.from("#second-section-bg", {
                scale: 1.3,
                duration: 1,
                ease: "power1.out",
                scrollTrigger: {
                    trigger: "#second-section",
                    // scroller: "#main-scroller",
                    // markers: true,
                    start: "top top",
                    toggleActions: "play pause resume reverse",
                },
            });

            const sidebarTl = gsap
                .timeline({ paused: true })
                .from("#sidebar", {
                    x: "100vw",
                    ease: "power4.out",
                    easeReverse: "power1.in",
                    duration: 1,
                })
                .from("#sidebar-link", { x: -80, ease: "back", opacity: 0, stagger: 0.1 }, "<0.3");

            const hamMenuBtn = document.getElementById("ham-menu-btn");
            hamMenuBtn?.addEventListener("click", () => {
                if (!hamMenuBtn.classList.contains("active")) {
                    sidebarTl.duration(1).play();
                } else {
                    sidebarTl.duration(0.2).reverse();
                }
                hamMenuBtn.classList.toggle("active");
            });

            // const infoHolderHeight = document.querySelector(".card")?.clientHeight || 0;
            // const cardsLength = document.querySelectorAll(".card").length;
            // gsap.to("#cards-wrapper", {
            //     y: infoHolderHeight * -(cardsLength - 1),
            //     scrollTrigger: {
            //         trigger: "#second-section",
            //         toggleActions: "play pause restart reset",
            //         scrub: 1.5,
            //         pin: true,
            //         start: "top top",
            //         end: `+=${infoHolderHeight * cardsLength}`,
            //     },
            // });

            const cardImages = gsap.utils.toArray<HTMLElement>(".card-image");
            const cardTexts = gsap.utils.toArray<HTMLElement>(".card-text");

            const cardsTimeline = gsap.timeline({
                scrollTrigger: {
                    trigger: "#second-section",
                    start: "top top",
                    end: "+=3000",
                    scrub: 1,
                    pin: true,
                    // markers: true,
                },
            });

            cardImages.forEach((image, index) => {
                const text = cardTexts[index];
                let opacity = 0;
                if (index === cardImages.length - 1) {
                    opacity = 1;
                }

                cardsTimeline
                    .from(image, {
                        scale: 0,
                        x: -1500,
                        rotate: -360,
                        filter: "blur(30px)",
                        ease: "power2.out",
                    })
                    .fromTo(text, { opacity: 0 }, { opacity: 1, delay: 0.2 }, "<")
                    .to(text, {
                        opacity: opacity,
                    });
            });

            const watchTrailerTimeline = gsap
                .timeline({
                    scrollTrigger: {
                        trigger: "#video-sec",
                        start: "-120px top",
                        // toggleActions: "play none play none",
                        toggleActions: "play pause resume reverse",
                        // markers: true,
                        onEnter: () => watchTrailerTimeline.timeScale(2).play(),
                        onLeaveBack: () => watchTrailerTimeline.timeScale(5).reverse(),
                    },
                })
                .from("#hole", {
                    scale: 0,
                    repeat: 1,
                    yoyo: true,
                })
                .fromTo("#play-btn", { y: 190, scaleY: 2.5 }, { y: -220, scaleY: 1 }, 0.2)
                .to("#play-btn", { y: -4, ease: "power1.in" }, ">")
                .to("#play-btn", {
                    scaleY: 0.8,
                    scaleX: 1.3,
                    transformOrigin: "50% 100%",
                    duration: 0.15,
                    repeat: 1,
                    yoyo: true,
                })
                .from("#watch", { opacity: 0, x: 100, ease: "back", duration: 1 }, "<-0.1")
                .from("#now", { opacity: 0, x: -100, ease: "back", duration: 1 }, "<0.5");
        });

        const imageHolder = document.getElementById("game-img-holder") as HTMLImageElement;
        const lolBtn = document.getElementById("lol-btn");
        const valorantBtn = document.getElementById("valorant-btn");
        const lorBtn = document.getElementById("lor-btn");
        lolBtn?.addEventListener("click", () => {
            imageHolder.src = "/league-of-legends.jpg";
            valorantBtn?.classList.remove("active-game-btn");
            lorBtn?.classList.remove("active-game-btn");
            lolBtn?.classList.add("active-game-btn");
        });
        valorantBtn?.addEventListener("click", () => {
            imageHolder.src = "/valorant.jpg";
            lolBtn?.classList.remove("active-game-btn");
            lorBtn?.classList.remove("active-game-btn");
            valorantBtn?.classList.add("active-game-btn");
        });
        lorBtn?.addEventListener("click", () => {
            imageHolder.src = "/legends-of-runeterra.jpg";
            valorantBtn?.classList.remove("active-game-btn");
            lolBtn?.classList.remove("active-game-btn");
            lorBtn?.classList.add("active-game-btn");
        });
    </script>
</html>
});

