---
import "../styles/global.css";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Astro</title>
    </head>
    <body class="bg-black/90 text-white relative pb-40 scroll-smooth">
        <!-- <div -->
        <!--     class="notif border absolute text-white font-bold p-2 bg-green-400 right-1/2 translate-x-1/2 rounded-md" -->
        <!-- > -->
        <!--     Message Sent ✅ -->
        <!-- </div> -->
        <div id="sidebar" class="backdrop-blur-[2px] bg-black/30 w-[50vw] p-8 absolute flex justify-center gap-8 flex-col h-screen z-20">
            <button id="close-sidebar-btn" class="absolute left-4 top-2 border rounded-full w-8 h-8 cursor-pointer">X</button>
            <div id="sidebar-link" class="flex items-center group gap-3 cursor-pointer">
                <div class="w-6 h-6 rounded-full bg-[#888] group-hover:scale-150 group-hover:bg-orange-500 duration-150"></div>
                <div
                    class="text-5xl font-extrabold text-[#999] tracking-tighter group-hover:text-white group-hover:translate-x-3 group-hover:scale-110 scale:150 origin-left duration-150"
                >
                    HOME
                </div>
            </div>

            <div id="sidebar-link" class="flex items-center group gap-3 cursor-pointer">
                <div class="w-6 h-6 rounded-full bg-[#888] group-hover:scale-150 group-hover:bg-orange-500 duration-150"></div>
                <div
                    class="text-5xl font-extrabold text-[#999] tracking-tighter group-hover:text-white group-hover:translate-x-3 group-hover:scale-110 scale:150 origin-left duration-150"
                >
                    ABOUT
                </div>
            </div>

            <div id="sidebar-link" class="flex items-center group gap-3 cursor-pointer">
                <div class="w-6 h-6 rounded-full bg-[#888] group-hover:scale-150 group-hover:bg-orange-500 duration-150"></div>
                <div
                    class="text-5xl font-extrabold text-[#999] tracking-tighter group-hover:text-white group-hover:translate-x-3 group-hover:scale-110 scale:150 origin-left duration-150"
                >
                    SERVICES
                </div>
            </div>

            <div id="sidebar-link" class="flex items-center group gap-3 cursor-pointer">
                <div class="w-6 h-6 rounded-full bg-[#888] group-hover:scale-150 group-hover:bg-orange-500 duration-150"></div>
                <div
                    class="text-5xl font-extrabold text-[#999] tracking-tighter group-hover:text-white group-hover:translate-x-3 group-hover:scale-110 scale:150 origin-left duration-150"
                >
                    PROJECTS
                </div>
            </div>

            <div id="sidebar-link" class="flex items-center group gap-3 cursor-pointer">
                <div class="w-6 h-6 rounded-full bg-[#888] group-hover:scale-150 group-hover:bg-orange-500 duration-150"></div>
                <div
                    class="text-5xl font-extrabold text-[#999] tracking-tighter group-hover:text-white group-hover:translate-x-3 group-hover:scale-110 scale:150 origin-left duration-150"
                >
                    CONTACT US
                </div>
            </div>
        </div>
        <header class="flex justify-center border w-screen h-32">
            <button id="open-sidebar-btn" class="absolute left-4 top-2">|||</button>
            <div
                id="banner"
                class="w-44 h-12 border-4 mt-2 grid place-items-center rounded-md bg-amber-800 text-white font-bold perspective-dramatic"
            >
                AGENCY
            </div>
        </header>

        <div class="h-[40vh] flex items-center justify-center gap-6 bg-zinc-900 [&>button]:cursor-pointer">
            <button class="btn px-6 py-3 rounded-xl bg-blue-500 text-white font-semibold"> Home </button>

            <button class="btn px-6 py-3 rounded-xl bg-purple-500 text-white font-semibold"> About </button>

            <button class="btn px-6 py-3 rounded-xl bg-emerald-500 text-white font-semibold"> Contact </button>
        </div>

        <div id="box" class="overflow-hidden border mt-20 rounded mx-auto">
            <h3 id="fashion" class="text-4xl">Fashion</h3>
        </div>
        <div
            id="sections"
            class="flex h-[60vh] border text-white text-4xl [&>section]:grid [&>section]:place-items-center [&>section]:px-4 [&>section]:min-w-screen overflow-hidden"
        >
            <section class="border bg-blue-300 rounded">Section 1</section>
            <section class="border bg-red-300 rounded">Section 2</section>
            <section class="border bg-cyan-300 rounded">Section 3</section>
            <section class="border bg-purple-300 rounded">Section 4</section>
        </div>

        <div
            id="wrapper"
            class="w-30 relative bg-purple-300 h-30 overflow-hidden border mt-8 rounded-full mb-20 mx-auto grid place-items-center"
        >
            <div id="circlee" class="absolute rounded-full w-full h-full bg-purple-600"></div>
            <span class="z-10">Hover me</span>
        </div>

        <div
            id="parent"
            class="border flex gap- py-12 justify-center overflow-hidden text-3xl [&>div]:grid [&>div]:place-items-center text-white"
        >
            <div class="border w-20 h-20 rounded-2xl bg-amber-400">A</div>
            <div class="border w-20 h-20 rounded-2xl bg-amber-400">S</div>
            <div class="border w-20 h-20 rounded-2xl bg-amber-400">T</div>
            <div class="border w-20 h-20 rounded-2xl bg-amber-400">R</div>
            <div class="border w-20 h-20 rounded-2xl bg-amber-400">O</div>
        </div>
        <div id="herman-wrapper" class="h-[60vh] relative">
            <div id="hole" class="w-48 h-5 bg-black rounded-[50%] absolute top-[77%] right-1/2 translate-x-1/2"></div>

            <div
                id="shadow"
                class="opacity-0 w-48 h-5 rounded-full absolute right-1/2 translate-x-1/2 top-[77%] bg-[radial-gradient(rgba(100,100,100,0.8),rgba(0,0,0,0)_75%)] blur-xs"
            >
            </div>
            <div class="h-[80%] w-96 mx-auto relative overflow-hidden rounded-[50%]">
                <img
                    id="herman"
                    class="w-28 absolute bottom-0 right-1/2 translate-x-1/2"
                    src="https://assets.codepen.io/32887/herman.svg"
                    alt=""
                />
            </div>
        </div>

        <div class="mt-8 border p-8 flex items-center bg-black group gap-3">
            <div class="w-6 h-6 rounded-full bg-[#333] group-hover:scale-150 group-hover:bg-orange-500 duration-150"></div>
            <div
                class="text-5xl font-extrabold text-[#777] tracking-tighter group-hover:text-white group-hover:translate-x-3 group-hover:scale-110 scale:150 origin-left duration-150"
            >
                HOME
            </div>
        </div>

        <div class="mt-8 border p-8 flex items-center bg-black group gap-3">
            <div class="w-6 h-6 rounded-full bg-[#333] group-hover:scale-150 group-hover:bg-orange-500 duration-150"></div>
            <div
                class="text-5xl font-extrabold text-[#777] tracking-tighter group-hover:text-white group-hover:translate-x-3 group-hover:scale-110 origin-left scale:150 duration-150"
            >
                CONTACT US
            </div>
        </div>

        <div class="text border mt-8 p-8 text-xl rounded-2xl">When Marketing Goes Wrong...</div>
        <div class="p-8 border h-150 mt-8 rounded-2xl relative">
            <img id="herman2" class="w-28 absolute top-1/2 -translate-y-1/2" src="https://assets.codepen.io/32887/herman.svg" alt="" />
        </div>

        <div class="herman3-box p-8 border grid place-items-center h-150 mt-8 rounded-2xl relative">
            <img id="herman3" class="w-28" src="https://assets.codepen.io/32887/herman.svg" alt="" />
        </div>
        <div id="textDiv" class="h-[50vh] grid place-items-center w-96 border mt-8 mx-auto p-4 text-2xl">
            <p id="paragraph" class="perspective-dramatic">
                Lorem ipsum dolor, sit amet consectetur adipisicing elit. Reprehenderit vero impedit magni odio. Nostrum labore nulla velit
                ipsam, molestias totam!
            </p>
        </div>
        <div class="h-[50vh]"></div>

        <section id="second-section" class="border relative h-screen overflow-hidden grid place-items-center">
            <div id="second-section-bg" class="absolute inset-0 bg-[url('/bg2.png')] bg-cover bg-position-[30%_center] -z-10"></div>

            <div class="w-[80vw] h-[70vh] overflow-hidden rounded-md">
                <div id="cards-wrapper" class="h-full w-full">
                    <!-- VI -->
                    <div class="info-holder h-full w-full flex items-center justify-center gap-4">
                        <div class="bg-[url('/characters/vi.avif')] rounded-lg h-full w-120 bg-cover bg-center"></div>
                        <div class="text-center">
                            <p class="text-6xl font-extrabold">VI</p>
                            <p class="max-w-96 text-lg">
                                Accepting Powder is gone, Vi comes to terms with what she must do—handle the monster she created: Jinx.
                                Knowing how dangerous her sister is, Vi teams up with Caitlyn and gives in to her request to don the
                                Enforcer badge.
                            </p>
                        </div>
                    </div>

                    <!-- JINX -->
                    <div class="info-holder h-full w-full flex items-center justify-center gap-4">
                        <div class="bg-[url('/characters/jinx.avif')] rounded-lg h-full w-120 bg-cover bg-center"></div>
                        <div class="text-center">
                            <p class="text-6xl font-extrabold">JINX</p>
                            <p class="max-w-96 text-lg">
                                Accepting Powder is gone, Vi comes to terms with what she must do—handle the monster she created: Jinx.
                                Knowing how dangerous her sister is, Vi teams up with Caitlyn and gives in to her request to don the
                                Enforcer badge.
                            </p>
                        </div>
                    </div>

                    <div class="info-holder h-full w-full flex items-center justify-center gap-4">
                        <div class="bg-[url('/characters/jayce.avif')] rounded-lg h-full w-120 bg-cover bg-center"></div>
                        <div class="text-center">
                            <p class="text-6xl font-extrabold">VI</p>
                            <p class="max-w-96 text-lg">
                                Accepting Powder is gone, Vi comes to terms with what she must do—handle the monster she created: Jinx.
                                Knowing how dangerous her sister is, Vi teams up with Caitlyn and gives in to her request to don the
                                Enforcer badge.
                            </p>
                        </div>
                    </div>

                    <div class="info-holder h-full w-full flex items-center justify-center gap-4">
                        <div class="bg-[url('/characters/mel.avif')] rounded-lg h-full w-120 bg-cover bg-center"></div>
                        <div class="text-center">
                            <p class="text-6xl font-extrabold">VI</p>
                            <p class="max-w-96 text-lg">
                                Accepting Powder is gone, Vi comes to terms with what she must do—handle the monster she created: Jinx.
                                Knowing how dangerous her sister is, Vi teams up with Caitlyn and gives in to her request to don the
                                Enforcer badge.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </body>
</html>
<style></style>
<script>
    import { gsap } from "gsap";
    import { RoughEase } from "gsap/EasePack";
    import { GSDevTools } from "gsap/GSDevTools";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { SplitText } from "gsap/SplitText";
    gsap.registerPlugin(RoughEase, SplitText, GSDevTools, ScrollTrigger);

    const sidebarTl = gsap
        .timeline({ paused: true })
        .from("#sidebar", {
            x: "-50vw",
            ease: "power4.out",
            easeReverse: "power1.in",
            duration: 1,
        })
        .from("#sidebar-link", { x: -80, ease: "back", opacity: 0, stagger: 0.1 }, "<0.3");
    const closeSidebarBtn = document.getElementById("close-sidebar-btn");
    const openSidebarBtn = document.getElementById("open-sidebar-btn");
    openSidebarBtn?.addEventListener("click", () => sidebarTl.duration(1).play());
    closeSidebarBtn?.addEventListener("click", () => sidebarTl.duration(0.2).reverse());
    // const timeline = gsap.timeline({
    //     paused: true,
    //     scrollTrigger: {
    //         trigger: ".herman3-box",
    //         start: "top center",
    //         toggleActions: "play pause resume reset",
    //         scrub: true,
    //         pin: true,
    //     },
    // });
    //
    // timeline.to("#herman3", { scale: 0.4 });
    // timeline.to("#herman3", { scale: 3 });
    // timeline.to("#herman3", { rotation: 360 }, "<0.2");
    // timeline.to("#herman3", { scale: 1 }, "<0.1");

    gsap.timeline().from("#banner", {
        rotationX: -90,
        ease: "back(4)",
        duration: 3,
    });
    const textTl = gsap.timeline({
        paused: true,
        scrollTrigger: {
            trigger: "#textDiv",
            start: "top bottom",
            end: "top top",
            // markers: true,
            toggleActions: "play pause resume reset",
            scrub: 1,
        },
    });
    const splitted = SplitText.create("#paragraph", { type: "lines" });
    textTl.from(splitted.lines, {
        rotationX: -90,
        ease: "back(5)",
        opacity: 0,
        stagger: 0.2,
    });

    // GSDevTools.create({ animation: textTl });

    gsap.timeline().to("#herman2", {
        keyframes: {
            "0%": { y: 0 },
            "25%": { y: 0 },
            "50%": { y: -200 },
            "75%": { y: 0 },
            "100%": { x: 1000 },
        },
        duration: 2,
        repeat: 1,
        yoyo: true,
    });

    gsap.from(new SplitText(".text", { type: "words" }).words, {
        opacity: 0,
        rotation: -40,
        // y: 50,
        scale: 0.4,
        repeat: -1,
        ease: "back",
        stagger: 0.1,
    });

    const herman = gsap
        .timeline({ repeat: -1, yoyo: true, repeatDelay: 0.5 })
        .from("#hole", {
            scale: 0,
            repeat: 1,
            yoyo: true,
        })
        .fromTo("#herman", { y: 180, scaleY: 2 }, { y: -220, scaleY: 1 }, 0.2)
        .to("#herman", { y: -4, ease: "power1.in" }, ">")
        .to("#herman", {
            scaleY: 0.8,
            scaleX: 1.3,
            transformOrigin: "50% 100%",
            duration: 0.15,
            repeat: 1,
            yoyo: true,
        })
        .to("#shadow", { opacity: 1, duration: 0.1 }, 0.7)
        .to("#shadow", { scaleX: 0.5, ease: "power1.in" }, ">");

    // GSDevTools.create({ animation: herman });

    gsap.timeline()
        .from("#parent", { opacity: 0, duration: 1 })
        .from("#parent div", {
            y: 160,
            duration: 0.8,
            opacity: 0,
            stagger: 0.1,
        })
        .to("#parent div", {
            rotation: 360,
            ease: "back.out",
            stagger: 0.1,
        });
    const cubes = document.querySelectorAll("#parent div");
    cubes.forEach((cube) => {
        cube.addEventListener("mouseenter", () => {
            if (!gsap.isTweening(cube)) {
                gsap.to(cube, { rotation: "+=360" });
            }
        });
    });

    document.getElementById("wrapper")?.addEventListener("mouseenter", () => {
        console.log("entered");
        gsap.fromTo("#circlee", { scale: 0 }, { scale: 1, duration: 1, ease: "circ" });
    });
    // gsap.fromTo(
    //     ".ball",
    //     {
    //         scale: 0,
    //         opacity: 0,
    //     },
    //     {
    //         scale: 2,
    //         opacity: 0.5,
    //         duration: 1,
    //         repeat: -1,
    //         yoyo: true,
    //         ease: "power1.inOut",
    //     },
    // );

    document.querySelectorAll(".btn").forEach((btn) => {
        const originalColor = getComputedStyle(btn).backgroundColor;

        btn.addEventListener("mouseenter", () => {
            gsap.to(btn, {
                scale: 1.1,
                duration: 0.25,
                rotation: -10,
            });
            gsap.to(btn, {
                duration: 0,
                backgroundColor: "cyan",
            });
        });

        btn.addEventListener("mouseleave", () => {
            gsap.to(btn, {
                scale: 1,
                rotation: 0,
                duration: 0.25,
            });

            gsap.to(btn, {
                duration: 0,
                backgroundColor: originalColor,
            });
        });
    });

    gsap.from(".notif", {
        yPercent: -100,
        duration: 0.8,
        opacity: 0,
        ease: "bounce.out",
        rotation: -270,

        onComplete: () => {
            gsap.to(".notif", {
                yPercent: -100,
                opacity: 0,
                rotation: -270,
                duration: 0.5,
                delay: 1,
                ease: "power2.in",
            });
        },
    });

    gsap.to("#sections section", {
        x: "-=200vw",
        duration: 1,
        ease: "back.out",
        repeat: 3,
        repeatDelay: 1.5,
    });

    // gsap.to("#box", { x: 700, ease: "slow", duration: 1 });
    const tween = gsap.fromTo("#fashion", { x: "-30vw" }, { x: "100vw", paused: true, ease: "slow", duration: 2, delay: 0 });
    tween.play();
    // setTimeout(() => {
    //     tween.pause();
    // }, 1500);
    // gsap.to(".heading", {
    //     opacity: 1,
    //     stagger: 0.5,
    //     x: 500,
    //     y: 10,
    //     duration: 2,
    //     rotation: 360,
    //     ease: "back",
    //     scale: 2,
    //     color: "blue",
    //     repeatDelay: 1,
    //     repeat: 1,
    //     yoyo: true,
    // });
    // gsap.fromTo(
    //     ".astro",
    //     {
    //         opacity: 0,
    //         x: 0,
    //     },
    //     {
    //         color: "red",
    //         x: 200,
    //         opacity: 1,
    //         ease: "bounce",
    //         duration: 4,
    //         stagger: { amount: 0.5, from: "random" },
    //     },
    // );
    //

    const cardsWrapper = document.getElementById("cards-wrapper");
    // if (!cardsWrapper) return;
    gsap.to(cardsWrapper, {
        yPercent: (cardsWrapper?.childElementCount - 1) * -100,
        ease: "none",
        // duration: 5,
        // stagger: 1,
        scrollTrigger: {
            trigger: "#second-section",
            // scroller: "#main-scroller",
            // markers: true,
            start: "top top",
            end: `+=${cardsWrapper?.childElementCount * 1000}`,
            // toggleActions: "play pause resume reset",
            pin: true,
            scrub: 1,
        },
    });
</script>
