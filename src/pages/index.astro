---
import "../styles/global.css";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Astro</title>
    </head>
    <body class="p-2 relative pb-40">
        <div
            class="notif border absolute text-white font-bold p-2 bg-green-400 right-1/2 translate-x-1/2 rounded-md"
        >
            Message Sent ✅
        </div>

        <div
            class="h-[40vh] flex items-center justify-center gap-6 bg-zinc-900 [&>button]:cursor-pointer"
        >
            <button
                class="btn px-6 py-3 rounded-xl bg-blue-500 text-white font-semibold"
            >
                Home
            </button>

            <button
                class="btn px-6 py-3 rounded-xl bg-purple-500 text-white font-semibold"
            >
                About
            </button>

            <button
                class="btn px-6 py-3 rounded-xl bg-emerald-500 text-white font-semibold"
            >
                Contact
            </button>
        </div>

        <div
            class="ball absolute top-1/2 right-1/2 z-10 translate-y-1/2 translate-x-1/2"
        >
        </div>
        <div id="box" class="overflow-hidden border mt-20 rounded mx-auto">
            <h3 id="fashion" class="text-4xl">Fashion</h3>
        </div>
        <div
            id="sections"
            class="flex h-[60vh] border text-white text-4xl [&>section]:grid [&>section]:place-items-center [&>section]:px-4 [&>section]:min-w-screen overflow-hidden"
        >
            <section class="border bg-blue-300 rounded">Section 1</section>
            <section class="border bg-red-300 rounded">Section 2</section>
            <section class="border bg-cyan-300 rounded">Section 3</section>
            <section class="border bg-purple-300 rounded">Section 4</section>
        </div>

        <div
            id="wrapper"
            class="w-30 relative bg-purple-300 h-30 overflow-hidden border mt-8 rounded-full mb-20 mx-auto grid place-items-center"
        >
            <div
                id="circlee"
                class="absolute rounded-full w-full h-full bg-purple-600"
            >
            </div>
            <span class="z-10">Hover me</span>
        </div>

        <div
            id="parent"
            class="border flex gap- py-12 justify-center overflow-hidden text-3xl [&>div]:grid [&>div]:place-items-center text-white"
        >
            <div class="border w-20 h-20 rounded-2xl bg-amber-400">A</div>
            <div class="border w-20 h-20 rounded-2xl bg-amber-400">S</div>
            <div class="border w-20 h-20 rounded-2xl bg-amber-400">T</div>
            <div class="border w-20 h-20 rounded-2xl bg-amber-400">R</div>
            <div class="border w-20 h-20 rounded-2xl bg-amber-400">O</div>
        </div>
        <div class="border h-[60vh] relative">
            <div
                id="hole"
                class="w-48 h-5 bg-black rounded-[50%] absolute top-[77%] right-1/2 translate-x-1/2"
            >
            </div>

            <div
                id="shadow"
                class="opacity-0 w-48 h-5 rounded-full absolute right-1/2 translate-x-1/2 top-[77%] bg-[radial-gradient(rgba(100,100,100,0.8),rgba(0,0,0,0)_75%)] blur-xs"
            >
            </div>
            <div
                class="h-[80%] w-96 mx-auto relative overflow-hidden rounded-[50%]"
            >
                <img
                    id="herman"
                    class="w-28 absolute bottom-0 right-1/2 translate-x-1/2"
                    src="https://assets.codepen.io/32887/herman.svg"
                    alt=""
                />
            </div>
        </div>
    </body>
    <style>
        .ball {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: hotpink;
        }
    </style>
    <script>
        import { gsap } from "gsap";
        import { RoughEase } from "gsap/EasePack";
        import { GSDevTools } from "gsap/GSDevTools";
        gsap.registerPlugin(GSDevTools);
        gsap.registerPlugin(RoughEase);

        const herman = gsap
            .timeline({ repeat: -1, yoyo: true, repeatDelay: 0.5 })
            .from("#hole", {
                scale: 0,
                repeat: 1,
                yoyo: true,
            })
            .fromTo(
                "#herman",
                { y: 180, scaleY: 2 },
                { y: -220, scaleY: 1 },
                0.2,
            )
            .to("#herman", { y: -4, ease: "power1.in" }, ">")
            .to("#herman", {
                scaleY: 0.8,
                scaleX: 1.3,
                transformOrigin: "50% 100%",
                duration: 0.15,
                repeat: 1,
                yoyo: true,
            })
            .to("#shadow", { opacity: 1, duration: 0.1 }, 0.7)
            .to("#shadow", { scaleX: 0.5, ease: "power1.in" }, ">");

        // GSDevTools.create({ animation: herman });

        gsap.timeline()
            .from("#parent", { opacity: 0, duration: 1 })
            .from("#parent div", {
                y: 160,
                duration: 0.8,
                opacity: 0,
                stagger: 0.1,
            })
            .to("#parent div", {
                rotation: 360,
                ease: "back.out",
                stagger: 0.1,
            });
        const cubes = document.querySelectorAll("#parent div");
        cubes.forEach((cube) => {
            cube.addEventListener("mouseenter", () => {
                if (!gsap.isTweening(cube)) {
                    gsap.to(cube, { rotation: "+=360" });
                }
            });
        });

        document
            .getElementById("wrapper")
            ?.addEventListener("mouseenter", () => {
                console.log("entered");
                gsap.fromTo(
                    "#circlee",
                    { scale: 0 },
                    { scale: 1, duration: 1, ease: "circ" },
                );
            });
        // gsap.fromTo(
        //     ".ball",
        //     {
        //         scale: 0,
        //         opacity: 0,
        //     },
        //     {
        //         scale: 2,
        //         opacity: 0.5,
        //         duration: 1,
        //         repeat: -1,
        //         yoyo: true,
        //         ease: "power1.inOut",
        //     },
        // );

        document.querySelectorAll(".btn").forEach((btn) => {
            const originalColor = getComputedStyle(btn).backgroundColor;

            btn.addEventListener("mouseenter", () => {
                gsap.to(btn, {
                    scale: 1.1,
                    duration: 0.25,
                    rotation: -10,
                });
                gsap.to(btn, {
                    duration: 0,
                    backgroundColor: "cyan",
                });
            });

            btn.addEventListener("mouseleave", () => {
                gsap.to(btn, {
                    scale: 1,
                    rotation: 0,
                    duration: 0.25,
                });

                gsap.to(btn, {
                    duration: 0,
                    backgroundColor: originalColor,
                });
            });
        });

        gsap.from(".notif", {
            yPercent: -100,
            duration: 0.8,
            opacity: 0,
            ease: "bounce.out",
            rotation: -270,

            onComplete: () => {
                gsap.to(".notif", {
                    yPercent: -100,
                    opacity: 0,
                    rotation: -270,
                    duration: 0.5,
                    delay: 1,
                    ease: "power2.in",
                });
            },
        });

        gsap.to("#sections section", {
            x: "-=200vw",
            duration: 1,
            ease: "back.out",
            repeat: 3,
            repeatDelay: 1.5,
        });

        // gsap.to("#box", { x: 700, ease: "slow", duration: 1 });
        const tween = gsap.fromTo(
            "#fashion",
            { x: "-30vw" },
            { x: "100vw", paused: true, ease: "slow", duration: 2, delay: 0 },
        );
        tween.play();
        // setTimeout(() => {
        //     tween.pause();
        // }, 1500);
        // gsap.to(".heading", {
        //     opacity: 1,
        //     stagger: 0.5,
        //     x: 500,
        //     y: 10,
        //     duration: 2,
        //     rotation: 360,
        //     ease: "back",
        //     scale: 2,
        //     color: "blue",
        //     repeatDelay: 1,
        //     repeat: 1,
        //     yoyo: true,
        // });
        // gsap.fromTo(
        //     ".astro",
        //     {
        //         opacity: 0,
        //         x: 0,
        //     },
        //     {
        //         color: "red",
        //         x: 200,
        //         opacity: 1,
        //         ease: "bounce",
        //         duration: 4,
        //         stagger: { amount: 0.5, from: "random" },
        //     },
        // );
    </script>
</html>
